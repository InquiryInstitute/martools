# Copy to .env and set strong secrets before first boot.
# docker compose --profile analytics up -d   (etc.)

POSTGRES_PASSWORD=change-me-long-random

# Umami (analytics) — random 32+ chars
UMAMI_APP_SECRET=change-me-random-secret

# LiteLLM (optional) — set if you enable API key auth in config/litellm.yaml
# LITELLM_MASTER_KEY=sk-martools-local
